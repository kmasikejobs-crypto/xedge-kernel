const SCALE_FC1_W: f32 = 186.8639;
const SCALE_FC1_B: f32 = 46.465473;
const SCALE_FC2_W: f32 = 104.18028;
const SCALE_FC2_B: f32 = 53.522594;
const SCALE_FC3_W: f32 = 277.24307;
const SCALE_FC3_B: f32 = 156.12628;

pub struct GrokEdgeModel;

impl GrokEdgeModel {
    pub fn new() -> Self { Self }

    pub fn infer(&self, input: &[f32; 4]) -> [f32; 3] {
        let mut x1 = [0.0; 16];
        for i in 0..16 {
            let mut sum = Q_B1[i] as f32 / SCALE_FC1_B;
            for j in 0..4 {
                sum += (Q_W1[i * 4 + j] as f32 / SCALE_FC1_W) * input[j];
            }
            x1[i] = if sum > 0.0 { sum } else { 0.0 };
        }

        let mut x2 = [0.0; 8];
        for i in 0..8 {
            let mut sum = Q_B2[i] as f32 / SCALE_FC2_B;
            for j in 0..16 {
                sum += (Q_W2[i * 16 + j] as f32 / SCALE_FC2_W) * x1[j];
            }
            x2[i] = if sum > 0.0 { sum } else { 0.0 };
        }

        let mut out = [0.0; 3];
        for i in 0..3 {
            let mut sum = Q_B3[i] as f32 / SCALE_FC3_B;
            for j in 0..8 {
                sum += (Q_W3[i * 8 + j] as f32 / SCALE_FC3_W) * x2[j];
            }
            out[i] = sum;
        }
        out
    }
}

